generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= AUTHENTICATION (Better Auth) =================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(EDITOR)
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
}

enum Role {
  ADMIN
  EDITOR
}

// ================= PROFILE & GENERAL =================
model Profile {
  id          String   @id @default(cuid())
  fullName    String
  jobTitle    String
  bio         String   @db.Text
  avatarUrl   String?
  coverUrl    String?
  email       String?
  linkedinUrl String?
  githubUrl   String?
  updatedAt   DateTime @updatedAt
}

model Education {
  id           String   @id @default(cuid())
  institution  String
  degree       String
  courses      String[]
  achievements String[]
  startDate    DateTime
  endDate      DateTime?
  order        Int      @default(0)
}

model Experience {
  id               String   @id @default(cuid())
  role             String
  company          String
  responsibilities String[]
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean  @default(false)
  order            Int      @default(0)
}

model Skill {
  id       String @id @default(cuid())
  name     String
  category String // Manufacturing, Database, Programming, Infrastructure
  order    Int    @default(0)
}

// ================= PROJECTS =================
model Project {
  id           String         @id @default(cuid())
  title        String
  overview     String         @db.Text
  technologies String[]
  learnings    String?        @db.Text
  isPublished  Boolean        @default(false)
  images       ProjectImage[]
  createdAt    DateTime       @default(now())
}

model MESProject {
  id           String         @id @default(cuid())
  title        String
  description  String         @db.Text
  technologies String[]
  challenges   String         @db.Text
  solutions    String         @db.Text
  results      String         @db.Text
  isPublished  Boolean        @default(false)
  images       ProjectImage[]
}

model ProjectImage {
  id           String      @id @default(cuid())
  url          String
  projectId    String?
  mesProjectId String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mesProject   MESProject? @relation(fields: [mesProjectId], references: [id], onDelete: Cascade)
}

model Award {
  id          String   @id @default(cuid())
  title       String
  issuer      String
  date        DateTime
  description String?  @db.Text
  model3dUrl  String?  // Optional path to 3D trophy model
}

// ================= BLOG & CONTENT =================
model BlogPost {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  content     String         @db.Text // Tiptap HTML
  coverImage  String?
  isPublished Boolean        @default(false)
  categoryId  String
  category    BlogCategory   @relation(fields: [categoryId], references: [id])
  tags        BlogTag[]
  comments    Comment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model BlogTag {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model Comment {
  id        String   @id @default(cuid())
  author    String
  content   String   @db.Text
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ================= MEDIA (Photography & Adventure) =================
model PhotoAlbum {
  id         String   @id @default(cuid())
  title      String
  category   String   // Street, Landscape, Travel, Night
  coverImage String?
  photos     Photo[]
  createdAt  DateTime @default(now())
}

model Photo {
  id           String      @id @default(cuid())
  url          String
  exifInfo     Json?
  tags         String[]
  photoAlbumId String
  album        PhotoAlbum  @relation(fields: [photoAlbumId], references: [id], onDelete: Cascade)
}

model AdventureStory {
  id             String             @id @default(cuid())
  title          String
  content        String             @db.Text
  location       String
  routeInfo      String?            @db.Text
  lessonsLearned String?            @db.Text
  date           DateTime
  galleries      AdventureGallery[]
}

model AdventureGallery {
  id               String         @id @default(cuid())
  url              String
  adventureStoryId String
  story            AdventureStory @relation(fields: [adventureStoryId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  publicId  String   @unique
  folder    String   // /profile, /projects, /mes, etc.
  format    String
  size      Int
  createdAt DateTime @default(now())
}

// ================= SYSTEM & SETTINGS =================
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HomepageSection {
  id          String  @id @default(cuid())
  sectionName String  @unique
  title       String
  description String? @db.Text
  isEnabled   Boolean @default(true)
  order       Int     @default(0)
}

model SEOSetting {
  id          String @id @default(cuid())
  page        String @unique
  title       String
  description String
  keywords    String
  ogImage     String?
}

model VisitorAnalytics {
  id        String   @id @default(cuid())
  path      String
  source    String?
  visitedAt DateTime @default(now())
}