generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= AUTHENTICATION (Better Auth) =================
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("EDITOR")
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ================= HOMEPAGE =================
model HomeProfile {
  id          String   @id @default("home_config") // Fix cứng ID để chỉ có 1 bản ghi
  fullName    String   @default("Le Dat")
  status      String   @default("System Online & Operating")
  primaryRole String   @default("IT/ System Administrator")
  skills      String[] @default(["Data Science", "Data Engineering", "MES Solutions"])
  location    String   @default("Ho Chi Minh City")
  bio         String   @db.Text
  updatedAt   DateTime @updatedAt
  isShowExperience Boolean @default(true)
  isShowEducation  Boolean @default(true)
  isShowProjects   Boolean @default(true)
  isShowBlog       Boolean @default(true)
  isShowMedia      Boolean @default(true)
}

// ================= PROFILE & GENERAL =================
model Profile {
  id          String   @id @default(cuid())
  email       String?
  linkedinUrl String?
  githubUrl   String?
  updatedAt   DateTime @updatedAt
}

model Education {
  id           String   @id @default(cuid())
  institution  String
  degree       String
  courses      String[]
  achievements String[]
  startDate    DateTime
  endDate      DateTime?
  order        Int      @default(0)
}

model Experience {
  id               String   @id @default(cuid())
  role             String
  company          String
  responsibilities String[]
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean  @default(false)
  order            Int      @default(0)
}

model Skill {
  id       String @id @default(cuid())
  name     String
  category String // Manufacturing, Database, Programming, Infrastructure
  order    Int    @default(0)
}

// ================= PROJECTS =================
model Project {
  id           String         @id @default(cuid())
  title        String
  description  String
  content      String         @db.Text
  imageUrl     String?
  githubUrl    String?
  demoUrl      String?
  technologies String[]
  isPublished  Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  images       ProjectImage[]
}


model ProjectImage {
  id           String    @id @default(cuid())
  url          String
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Award {
  id          String   @id @default(cuid())
  title       String
  issuer      String
  date        DateTime
  description String?  @db.Text
  model3dUrl  String?  // Optional path to 3D trophy model
}

// ================= BLOG & CONTENT =================
model BlogPost {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  content     String         @db.Text // Tiptap HTML
  coverImage  String?
  isPublished Boolean        @default(false)
  categoryId  String
  category    BlogCategory   @relation(fields: [categoryId], references: [id])
  tags        BlogTag[]
  comments    Comment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model BlogTag {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model Comment {
  id        String   @id @default(cuid())
  author    String
  content   String   @db.Text
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ================= MEDIA (Photography & Adventure) =================
model PhotoAlbum {
  id         String   @id @default(cuid())
  title      String
  category   String   // Street, Landscape, Travel, Night
  coverImage String?
  photos     Photo[]
  createdAt  DateTime @default(now())
}

model Photo {
  id           String      @id @default(cuid())
  url          String
  exifInfo     Json?
  tags         String[]
  photoAlbumId String
  album        PhotoAlbum  @relation(fields: [photoAlbumId], references: [id], onDelete: Cascade)
}

model AdventureStory {
  id             String             @id @default(cuid())
  title          String
  content        String             @db.Text
  location       String
  routeInfo      String?            @db.Text
  lessonsLearned String?            @db.Text
  date           DateTime
  galleries      AdventureGallery[]
}

model AdventureGallery {
  id               String         @id @default(cuid())
  url              String
  adventureStoryId String
  story            AdventureStory @relation(fields: [adventureStoryId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  publicId  String   @unique
  folder    String   // /profile, /projects, /mes, etc.
  format    String
  size      Int
  createdAt DateTime @default(now())
}

// ================= SYSTEM & SETTINGS =================
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HomepageSection {
  id          String  @id @default(cuid())
  sectionName String  @unique
  title       String
  description String? @db.Text
  isEnabled   Boolean @default(true)
  order       Int     @default(0)
}

model SEOSetting {
  id          String @id @default(cuid())
  page        String @unique
  title       String
  description String
  keywords    String
  ogImage     String?
}

model VisitorAnalytics {
  id        String   @id @default(cuid())
  path      String
  source    String?
  visitedAt DateTime @default(now())
}

model GlobalSetting {
  id          String   @id @default("site_config") // Cố định ID để chỉ có 1 bản ghi duy nhất
  siteName    String   @default("Lê Văn Đạt Portfolio")
  logoUrl     String?
  faviconUrl  String?
  updatedAt   DateTime @updatedAt
}